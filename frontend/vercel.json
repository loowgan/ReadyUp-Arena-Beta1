{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "yarn install",
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "routes": [
    {
      "src": "/backend/api/(.*)",
      "dest": "https://readyup-arena-api.onrender.com/api/$1"
    },
    {
      "src": "/backend/health/ready",
      "dest": "https://readyup-arena-api.onrender.com/health/ready"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
