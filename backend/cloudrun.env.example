MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?appName=Cluster0
DB_NAME=readyup_arena
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_UPSTASH_HOST:6379

JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=you@example.com

SEED_ADMIN_EMAIL=you@example.com
SEED_ADMIN_PASSWORD=replace-with-a-strong-password
SEED_ADMIN_PSEUDO=Admin
SEED_ADMIN_COUNTRY=FR
SEED_ADMIN_TOKENS=1000

FRONTEND_URL=https://your-frontend-domain
BACKEND_PUBLIC_URL=https://your-api-domain
CORS_ORIGINS=https://your-frontend-domain,https://www.your-frontend-domain
CORS_ALLOW_CREDENTIALS=false

FEATURE_STEAM_AUTH=true
FEATURE_TWITCH=true
FEATURE_STRIPE_DONATIONS=false
FEATURE_PAYPAL=false
FEATURE_CSSTATS=false

TWITCH_CHANNEL=esl_csgo
MATCHZY_WEBHOOK_SECRET=replace-with-another-long-random-secret
RCON_ENC_KEY=replace-with-a-fernet-compatible-key

RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

STRIPE_API_KEY=
